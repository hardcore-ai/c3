{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "Restricted allowlist for SkillWall Live (cohorte2). Tools needed to execute the CONSTRUCTION phase end-to-end: infra (Terraform), backend (Node.js Lambda), frontend (Next.js + Vercel), and E2E tests (Playwright MCP). `rm` and `terraform apply` are intentionally NOT in the allowlist and will always prompt for confirmation.",
  "permissions": {
    "allow": [
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(chmod:*)",
      "Bash(which:*)",
      "Bash(wc:*)",
      "Bash(file:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(node:*)",
      "Bash(npm install:*)",
      "Bash(npm ci:*)",
      "Bash(npm run:*)",
      "Bash(npm view:*)",
      "Bash(npx tsc:*)",
      "Bash(npx jest:*)",
      "Bash(npx eslint:*)",
      "Bash(npx next:*)",
      "Bash(terraform init:*)",
      "Bash(terraform validate:*)",
      "Bash(terraform plan:*)",
      "Bash(terraform output:*)",
      "Bash(terraform fmt:*)",
      "Bash(terraform state list:*)",
      "Bash(terraform refresh:*)",
      "Bash(aws sts get-caller-identity:*)",
      "Bash(aws configure list:*)",
      "Bash(aws lambda get-function:*)",
      "Bash(aws lambda get-function-configuration:*)",
      "Bash(aws lambda list-functions:*)",
      "Bash(aws lambda invoke:*)",
      "Bash(aws lambda wait:*)",
      "Bash(aws lambda update-function-code:*)",
      "Bash(aws lambda update-function-configuration:*)",
      "Bash(aws apigatewayv2 get-api:*)",
      "Bash(aws apigatewayv2 get-apis:*)",
      "Bash(aws apigatewayv2 update-api:*)",
      "Bash(aws dynamodb describe-table:*)",
      "Bash(aws dynamodb scan:*)",
      "Bash(aws dynamodb query:*)",
      "Bash(aws s3 ls:*)",
      "Bash(aws s3api list-objects:*)",
      "Bash(aws logs describe-log-groups:*)",
      "Bash(aws logs filter-log-events:*)",
      "Bash(aws logs tail:*)",
      "Bash(vercel --version)",
      "Bash(vercel whoami:*)",
      "Bash(vercel link:*)",
      "Bash(vercel projects:*)",
      "Bash(vercel env:*)",
      "Bash(vercel env ls:*)",
      "Bash(vercel env add:*)",
      "Bash(vercel env rm:*)",
      "Bash(vercel --prod:*)",
      "Bash(vercel deploy:*)",
      "Bash(vercel inspect:*)",
      "Bash(printf:*)",
      "Bash(curl:*)",
      "Bash(zip:*)",
      "Bash(unzip:*)",
      "Bash(jq:*)",
      "Bash(base64:*)",
      "Bash(date:*)",
      "Bash(mktemp:*)",
      "Bash(sed:*)",
      "Bash(env)",
      "Bash(git status:*)",
      "Bash(git branch:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git checkout -b:*)",
      "Bash(./scripts/deploy.sh:*)",
      "Bash(./scripts/env-add.sh:*)",
      "Bash(./scripts/seed-session.sh:*)",
      "Bash(./infra/*.sh)",
      "Bash(./backend/scripts/*.sh)",
      "Bash(./frontend/scripts/*.sh)",
      "mcp__playwright__browser_navigate",
      "mcp__playwright__browser_snapshot",
      "mcp__playwright__browser_click",
      "mcp__playwright__browser_type",
      "mcp__playwright__browser_evaluate",
      "mcp__playwright__browser_console_messages",
      "mcp__playwright__browser_network_requests",
      "mcp__playwright__browser_network_request",
      "mcp__playwright__browser_take_screenshot",
      "mcp__playwright__browser_wait_for",
      "mcp__playwright__browser_press_key",
      "mcp__playwright__browser_resize",
      "mcp__playwright__browser_close"
    ],
    "deny": []
  }
}
